# Required
DISCORD_BOT_TOKEN=

# OpenAI integration (required for /ask and mention replies)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_OUTPUT_TOKENS=500

# Optional: set for fast guild-specific slash command sync.
# If empty, commands are synced globally.
TARGET_GUILD_ID=
ENABLE_MESSAGE_CONTENT_INTENT=true
EVENT_MANAGER_ROLE_ID=1483074945561923584
EVENTS_PAGE_URL=http://192.168.0.108/events.php
